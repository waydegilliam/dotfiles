{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#1f2328",
    "margin": 2
  },
  "block_quote": {
    "color": "#59636e",
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#1f2328",
    "bold": true
  },
  "h1": {
    "prefix": "# "
  },
  "h2": {
    "prefix": "## "
  },
  "h3": {
    "prefix": "### "
  },
  "h4": {
    "prefix": "#### "
  },
  "h5": {
    "prefix": "##### "
  },
  "h6": {
    "prefix": "###### ",
    "color": "#59636e",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "#d1d9e0",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#0969da",
    "underline": true
  },
  "link_text": {
    "color": "#0969da",
    "bold": true
  },
  "image": {
    "color": "#0969da",
    "underline": true
  },
  "image_text": {
    "color": "#59636e",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#1f2328",
    "background_color": "#eff1f3"
  },
  "code_block": {
    "color": "#1f2328",
    "margin": 2,
    "chroma": {
      "text": {
        "color": "#1f2328"
      },
      "error": {
        "color": "#f6f8fa",
        "background_color": "#cf222e"
      },
      "comment": {
        "color": "#59636e"
      },
      "comment_preproc": {
        "color": "#cf222e"
      },
      "keyword": {
        "color": "#cf222e"
      },
      "keyword_reserved": {
        "color": "#cf222e"
      },
      "keyword_namespace": {
        "color": "#cf222e"
      },
      "keyword_type": {
        "color": "#cf222e"
      },
      "operator": {
        "color": "#cf222e"
      },
      "punctuation": {
        "color": "#1f2328"
      },
      "name": {
        "color": "#1f2328"
      },
      "name_builtin": {
        "color": "#0550ae"
      },
      "name_tag": {
        "color": "#116329"
      },
      "name_attribute": {
        "color": "#0550ae"
      },
      "name_class": {
        "color": "#953800"
      },
      "name_constant": {
        "color": "#0550ae"
      },
      "name_decorator": {
        "color": "#6639ba"
      },
      "name_exception": {
        "color": "#953800"
      },
      "name_function": {
        "color": "#6639ba"
      },
      "name_other": {
        "color": "#1f2328"
      },
      "literal": {},
      "literal_number": {
        "color": "#0550ae"
      },
      "literal_date": {
        "color": "#0a3069"
      },
      "literal_string": {
        "color": "#0a3069"
      },
      "literal_string_escape": {
        "color": "#0550ae"
      },
      "generic_deleted": {
        "color": "#82071e",
        "background_color": "#ffebe9"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "#116329",
        "background_color": "#dafbe1"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "#59636e"
      },
      "background": {
        "background_color": "#f6f8fa"
      }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n→ "
  },
  "html_block": {},
  "html_span": {}
}
